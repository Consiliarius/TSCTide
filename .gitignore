# Environment
.env

# Python
__pycache__/
*.pyc
*.pyo
.venv/
.pytest_cache/
*.egg-info/

# Data directory — bind-mounted to container at /app/data.
# All contents are runtime/user data and must not be committed.
# The directory itself is tracked via .gitkeep so it exists on fresh clone
# (Docker requires the bind mount target to exist on the host before compose up).
data/*
!data/.gitkeep

# Operational backups
*.bak

# OS
.DS_Store
Thumbs.db

#Claude
Claude.md
.claude/*
docs/SESSION_RESUME.md

# Harmonic validation run outputs (scripts/stress_test_harmonic.py default --out-dir .)
/cache/
/stress_report.txt
/stress_report.json