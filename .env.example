# === API Keys ===
UKHO_API_KEY=your_ukho_api_key_here
OWM_API_KEY=your_openweathermap_api_key_here

# === UKHO Station ===
# Langstone Harbour = 0066 (secondary port, limited data)
# Portsmouth = 0065 (standard port, full predictions)
# If Langstone returns insufficient data, Portsmouth + offset is used automatically.
UKHO_STATION_ID=0066
UKHO_FALLBACK_STATION_ID=0065

# === Scheduling ===
# Daily UKHO fetch time (24hr format, local time)
UKHO_FETCH_HOUR=2
UKHO_FETCH_MINUTE=0

# Hours after HW at which to sample wind for swing offset
# Default: 4 (i.e. HW+4h, roughly mid-ebb when boat settles)
WIND_SAMPLE_HW_OFFSET_HOURS=4

# === Location (for OWM weather queries) ===
LOCATION_LAT=50.8185
LOCATION_LON=-0.9806

# === Defaults ===
DEFAULT_TIMEZONE=Europe/London

# === Server ===
PORT=8866

# === HTTPS (Cloudflare Tunnel — optional) ===
# Create a tunnel at https://one.dash.cloudflare.com/ → Networks → Tunnels
# Configure the public hostname (tsctide.uk) to route to http://tidal-access:8866
# Paste the tunnel token below, then start with: docker compose --profile https up -d
# No inbound ports needed. See README for full setup instructions.
# CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here
